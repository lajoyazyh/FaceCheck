APP_PROFILE=prod
FACECHECK_BACKEND_HOST_PORT=18080

POSTGRES_DB=facecheck
POSTGRES_USER=facecheck
POSTGRES_PASSWORD=replace-with-a-strong-postgres-password

DB_URL=jdbc:postgresql://postgres:5432/facecheck
DB_USERNAME=facecheck
DB_PASSWORD=replace-with-a-strong-postgres-password

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=replace-with-a-strong-redis-password

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=facecheck
RABBITMQ_PASSWORD=replace-with-a-strong-rabbitmq-password

JWT_ISSUER=facecheck
JWT_SECRET=replace-with-a-32-character-or-longer-secret
JWT_EXPIRES_MINUTES=120

# FRS is still incomplete. Keep HUAWEI_CLOUD_ENABLED=false until real FRS lands.
# Real OBS can be enabled independently with OBS_ENABLED=true.
# When OBS_ENABLED=true, configure FRS_AK, FRS_SK, OBS_ENDPOINT, OBS_REGION, and OBS_BUCKET.
# Do not paste real AK/SK into git-tracked files or chat logs.
HUAWEI_CLOUD_ENABLED=false
OBS_ENABLED=false
FRS_AK=
FRS_SK=
FRS_PROJECT_ID=
FRS_REGION=
FRS_ENDPOINT=
FRS_FACE_SET_NAME=facecheck-default
FRS_SIMILARITY_THRESHOLD=85

OBS_ENDPOINT=
OBS_REGION=
OBS_BUCKET=

CHECKIN_RATE_LIMIT_WINDOW_SECONDS=60
CHECKIN_RATE_LIMIT_MAX_REQUESTS=5
CHECKIN_IDEMPOTENCY_TTL_HOURS=24
